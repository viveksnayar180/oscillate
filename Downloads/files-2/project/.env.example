# Copy this to .env.local and fill in your values

# ─── Anthropic (optional) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
VITE_ANTHROPIC_KEY=

# ─── Razorpay ──────────────────────────────────────────────────────────────
# Get keys: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* for testing (no real charges), rzp_live_* for production

# Server-side ONLY — NEVER expose these in the browser
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Client-side safe (only opens checkout modal)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Google Pay / UPI ──────────────────────────────────────────────────────
# Your UPI ID — e.g. oscillate@okicici, yourmobile@upi, youremail@googlepay
VITE_UPI_ID=oscillate@googlepay
VITE_UPI_NAME=OSCILLATE

# ─── Supabase (Ticket DB + Venue Check-in) ──────────────────────────────────
# Create a free project at supabase.com, then:
# 1. Run this SQL in the Supabase SQL editor:
#    CREATE TABLE tickets (
#      id bigint generated always as identity primary key,
#      ticket_id text unique not null,
#      qr_data text not null,
#      event_name text,
#      event_detail text,
#      customer_email text,
#      customer_name text,
#      payment_id text,
#      is_scanned boolean default false,
#      scanned_at timestamptz,
#      created_at timestamptz default now()
#    );
# 2. Copy URL + service role key from Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...   # service role key — NEVER expose client-side

# PIN for venue staff at oscillate.in/checkin (min 4 digits)
VENUE_CHECKIN_PIN=1234

# ─── Resend (Email) ─────────────────────────────────────────────────────────
# Get API key: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Domain you've verified in Resend — or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=tickets@oscillate.in
# Optional: Resend audience ID for mailing list (Resend → Audiences → create one)
RESEND_AUDIENCE_ID=

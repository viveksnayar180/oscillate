# Copy this to .env.local and fill in your values

# ─── Anthropic (optional) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
VITE_ANTHROPIC_KEY=

# ─── Razorpay ──────────────────────────────────────────────────────────────
# Get keys: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* for testing (no real charges), rzp_live_* for production

# Server-side ONLY — NEVER expose these in the browser
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Client-side safe (only opens checkout modal)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Google Pay / UPI ──────────────────────────────────────────────────────
# Your UPI ID — e.g. oscillate@okicici, yourmobile@upi, youremail@googlepay
VITE_UPI_ID=oscillate@googlepay
VITE_UPI_NAME=OSCILLATE

# ─── Supabase (Ticket DB + Venue Check-in) ──────────────────────────────────
# Create a free project at supabase.com, then:
# 1. Run this SQL in the Supabase SQL editor:
#    CREATE TABLE tickets (
#      id bigint generated always as identity primary key,
#      ticket_id text unique not null,
#      qr_data text not null,
#      event_name text,
#      event_detail text,
#      customer_email text,
#      customer_name text,
#      payment_id text,
#      is_scanned boolean default false,
#      scanned_at timestamptz,
#      created_at timestamptz default now()
#    );
# 2. Copy URL + service role key from Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...   # service role key — NEVER expose client-side

# 3. Enable Row-Level Security so users can only read their own tickets:
#    ALTER TABLE tickets ENABLE ROW LEVEL SECURITY;
#    CREATE POLICY "users see own tickets" ON tickets FOR SELECT
#      USING (customer_email = auth.jwt() ->> 'email');
# 4. Copy URL + anon/public key for the browser client (safe to expose)
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...  # anon key — safe for browser

# PIN for venue staff at oscillate.in/checkin (min 4 digits)
VENUE_CHECKIN_PIN=1234

# PIN for admin dashboard at oscillate.in/admin (keep secret)
ADMIN_PIN=your-admin-pin-here

# ─── Tier 3 — Promo codes (Supabase table) ──────────────────────────────────
# CREATE TABLE promo_codes (
#   code text primary key,
#   discount_type text not null,  -- 'percent' or 'flat'
#   discount_value integer not null,
#   max_uses integer,
#   uses integer default 0,
#   expires_at timestamptz,
#   active boolean default true,
#   created_at timestamptz default now()
# );
#
# ─── Tier 3 — Waitlist (Supabase table) ─────────────────────────────────────
# CREATE TABLE waitlist (
#   id bigint generated always as identity primary key,
#   email text not null,
#   event_id integer not null,
#   event_name text,
#   tier_name text,
#   created_at timestamptz default now(),
#   unique(email, event_id, tier_name)
# );
#
# ─── Tier 3 — Ticket amount/tier columns ────────────────────────────────────
# ALTER TABLE tickets ADD COLUMN IF NOT EXISTS amount integer default 0;
# ALTER TABLE tickets ADD COLUMN IF NOT EXISTS tier text;

# ─── Resend (Email) ─────────────────────────────────────────────────────────
# Get API key: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Domain you've verified in Resend — or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=tickets@oscillate.in
# Optional: Resend audience ID for mailing list (Resend → Audiences → create one)
RESEND_AUDIENCE_ID=

# ─── Twilio (WhatsApp confirmations) ────────────────────────────────────────
# Sign up: https://www.twilio.com — free trial includes WhatsApp sandbox
# Sandbox testing: join sandbox at https://www.twilio.com/console/sms/whatsapp/sandbox
#   TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   (sandbox number)
# Production: requires Meta Business Account + approved WhatsApp sender
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
